# ─── База данных ────────────────────────────────────────────────────────────
# В проде используем PostgreSQL (поднимается через docker-compose).
# Для локальной разработки можно временно переключиться на SQLite.

# PostgreSQL (рекомендуется, совпадает с docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://incomelab:incomelab@localhost:5432/incomelab

# SQLite (только локально / для тестов)
# DATABASE_URL=sqlite:///./data/income.db

# ─── Настройки приложения ───────────────────────────────────────────────────
APP_PORT=5000
APP_ENV=development

# ─── Параметры PostgreSQL для docker-compose ────────────────────────────────
POSTGRES_USER=incomelab
POSTGRES_PASSWORD=incomelab
POSTGRES_DB=incomelab
POSTGRES_PORT=5432
